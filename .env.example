# ===== AI Co-Scientist 环境变量配置 =====
# 复制本文件为 .env,填入真实密钥。.env 不要提交到 git。

# ============================================================
#  LLM 路由:固定走 GPT/Claude 中转站
# ============================================================
# chat/reasoner 走 GPT 中转站,critical 走 Claude 中转站。
# USE_RELAY 仅作为旧配置兼容字段保留;即使写 false,代码也不会切回旧供应商。
USE_RELAY=true

# ---- 中转站(必填) ----
# GPT 中转站(承担 chat/reasoner)
RELAY_GPT_BASE_URL=https://right.codes/codex/v1
RELAY_GPT_API_KEY=sk-your-gpt-relay-key
# Claude 中转站(承担 critical / Extended Thinking)
RELAY_CLAUDE_BASE_URL=https://www.right.codes
RELAY_CLAUDE_API_KEY=sk-your-claude-relay-key
# 中转站对应的模型名(整理版 §3.2 推荐)
RELAY_MODEL_CHAT=gpt-5.5
RELAY_MODEL_REASONER=gpt-5.5
RELAY_MODEL_CRITICAL=claude-opus-4-7
RELAY_MODEL_EMBEDDING=text-embedding-3-small

# ---- 基础设施(可选,MVP 阶段可不填,会自动降级为 SQLite/NetworkX) ----
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/co_scientist
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=co_scientist_pwd
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0

# ---- 成本预算(月预算,美元) ----
MONTHLY_BUDGET_USD=15.0

# ---- 日志与输出 ----
LOG_LEVEL=INFO
DATA_DIR=./data
OUTPUT_DIR=./data/outputs
CACHE_DIR=./data/cache
CHECKPOINT_DIR=./data/checkpoints

# ---- 运行时开关 ----
# 代码执行模式:generate_only / dry_run / full_execute
CODE_EXECUTION_MODE=generate_only
# 批判圆桌最大轮数
CRITIQUE_MAX_TURNS=12
# 是否开启 Prompt Cache(客户端侧缓存)
ENABLE_PROMPT_CACHE=true

# ============================================================
#  整理版架构开关(Phase B / C)
# ============================================================
# M0 候选课题发现器(整理版 §4)
USE_M0_DISCOVERY=true
M0_DEFAULT_K=3
M0_AUTO_SELECT_TOP=false

# M2.5 文献访问状态层(整理版 §5)
USE_M2_5_ACCESS_STATUS=true

# M5.5 ResearchGate 质量门禁(整理版 §8.2)
USE_M5_5_GATE=true
USE_M5_5_LLM=false   # true 时在启发式之上叠加 LLM 综合
