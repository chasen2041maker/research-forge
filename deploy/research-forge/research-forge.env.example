# Copy to /etc/research-forge/research-forge.env and replace every placeholder.
# This file is deliberately not a Docker Compose .env file: it configures host processes.
RF_DATABASE_URL=postgresql+psycopg2://research_forge:REPLACE_WITH_DATABASE_PASSWORD@127.0.0.1:5432/research_forge
RF_REDIS_URL=redis://127.0.0.1:6379/0
RF_REDIS_STREAM_PREFIX=research-forge:attempts
RF_REDIS_CONSUMER_GROUP=research-forge-workers
RF_REDIS_VISIBILITY_TIMEOUT_SECONDS=60
RF_REDIS_MAX_DELIVERY_ATTEMPTS=3
RF_API_TOKEN=REPLACE_WITH_A_LONG_RANDOM_BEARER_TOKEN
RF_SCHEMA_PATH=/opt/research-forge/docs/规范/科研复现任务规范_v1.schema.json
RF_POLICY_PATH=/etc/research-forge/execution-policy.json
RF_WORKSPACE_ROOT=/srv/research-forge/workspaces
RF_ARTIFACT_ROOT=/srv/research-forge/cas
RF_PAPER_ROOT=/srv/research-forge/papers
RF_BROKER_SOCKET_PATH=/var/lib/research-forge/broker/sandbox.sock
RF_BROKER_STATE_ROOT=/var/lib/research-forge/broker/completed-results
RF_BROKER_SOCKET_GROUP=research-forge
RF_CORS_ORIGINS=https://forge.example.invalid
RF_API_HOST=127.0.0.1
RF_API_PORT=8080
RF_LOG_LEVEL=INFO
RF_WORKER_OWNER=forge-worker-1
