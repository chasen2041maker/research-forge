{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/chasen2041maker/research-forge/docs/%E8%A7%84%E8%8C%83/%E7%A7%91%E7%A0%94%E5%A4%8D%E7%8E%B0%E4%BB%BB%E5%8A%A1%E8%A7%84%E8%8C%83_v1.schema.json",
  "title": "Research Forge ReproductionSpec v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "paper",
    "repository",
    "execution",
    "metric",
    "change_budget",
    "budget"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "mode": { "enum": ["reproduce", "repair", "ablation"] },
    "paper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "sha256", "extraction_profile"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "extraction_profile": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url_or_path", "commit_sha"],
      "properties": {
        "url_or_path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "commit_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_digest",
        "setup_mode",
        "setup_argv",
        "run_argv",
        "working_directory",
        "timeout_seconds",
        "network_policy",
        "allowed_domains"
      ],
      "properties": {
        "image_digest": { "type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$" },
        "setup_mode": { "enum": ["prebuilt", "lockfile"] },
        "setup_argv": { "$ref": "#/$defs/argv" },
        "run_argv": { "$ref": "#/$defs/nonEmptyArgv" },
        "working_directory": { "$ref": "#/$defs/relativePath" },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
        "network_policy": { "enum": ["offline", "allowlisted"] },
        "allowed_domains": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 253 }
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_path",
        "format",
        "json_pointer",
        "comparator",
        "expected_value",
        "tolerance",
        "unit"
      ],
      "properties": {
        "artifact_path": { "$ref": "#/$defs/relativePath" },
        "format": { "const": "json" },
        "json_pointer": { "type": "string", "pattern": "^/" },
        "comparator": { "enum": ["equals", "gte", "lte"] },
        "expected_value": { "type": "number" },
        "tolerance": { "type": "number", "minimum": 0 },
        "unit": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "change_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_paths",
        "max_files",
        "max_changed_lines",
        "max_candidate_commits",
        "max_candidate_runs"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/relativePath" }
        },
        "max_files": { "type": "integer", "minimum": 0, "maximum": 3 },
        "max_changed_lines": { "type": "integer", "minimum": 0, "maximum": 200 },
        "max_candidate_commits": { "type": "integer", "minimum": 0, "maximum": 1 },
        "max_candidate_runs": { "type": "integer", "minimum": 0, "maximum": 1 }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_wall_time_seconds", "max_cost_usd", "max_artifact_bytes", "max_log_bytes"],
      "properties": {
        "max_wall_time_seconds": { "type": "integer", "minimum": 1, "maximum": 14400 },
        "max_cost_usd": { "type": "number", "minimum": 0, "maximum": 100 },
        "max_artifact_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "max_log_bytes": { "type": "integer", "minimum": 1, "maximum": 104857600 }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "not": { "pattern": "(^[\\/])|(^|[\\/])\\.\\.([\\/]|$)|^[A-Za-z]:" }
    },
    "argv": {
      "type": "array",
      "maxItems": 64,
      "items": { "type": "string", "maxLength": 4096, "pattern": "^[^\\u0000]*$" }
    },
    "nonEmptyArgv": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "type": "string", "maxLength": 4096, "pattern": "^[^\\u0000]*$" }
    }
  }
}
